1 VERSIONINFO
    FILEVERSION @DNS_LIBS_VERSION_COMMAS@,0
    PRODUCTVERSION @DNS_LIBS_VERSION_COMMAS@,0
    FILEFLAGSMASK 0x17L
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x4L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
        BLOCK "StringFileInfo"
        BEGIN
                BLOCK "040904b0"
                BEGIN
                        VALUE "FileDescription", "adyg - AdGuard DNS query tool"
                        VALUE "LegalCopyright", "Copyright © Adguard Software Limited 2009-2026"
                        VALUE "CompanyName", "Adguard Software Ltd"
                        VALUE "ProductName", "AdGuard DNS libraries"
                        VALUE "ProductVersion", "@DNS_LIBS_VERSION_FULL@"
                        VALUE "OriginalFilename", "adyg.exe"
                        VALUE "InternalName", "adyg"
                END
        END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
